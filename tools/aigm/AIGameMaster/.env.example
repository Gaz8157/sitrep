# AI Game Master Bridge — environment configuration
# Copy this file to .env and fill in your values before running.

# Ollama configuration
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b

# Bridge server port
BRIDGE_PORT=5555

# Arma Reforger RCON
ARMA_RCON_HOST=127.0.0.1
ARMA_RCON_PORT=2302
ARMA_RCON_PASSWORD=change_me

# Optional: restrict which panel user IDs can interact with AI GM
# Leave blank to allow any authenticated panel user
ALLOWED_PANEL_USERS=
