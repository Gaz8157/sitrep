# SITREP Panel — Environment Configuration
# Copy this file to .env and fill in your values.
# Loaded automatically by the backend on startup.

# The public URL of your panel — where users access it.
# Local network:  http://192.168.1.100:8000
# With domain:    https://panel.yourdomain.com
# With Tailscale: http://100.x.x.x:8000
# This drives CORS, Discord OAuth redirect, and all URL defaults.
PANEL_URL=http://localhost:8000

# Optional: override the auto-generated secret key (useful for multi-node setups)
# SECRET_KEY=your-secret-here

# PlayerTracker mod auth key.
# install.sh generates a random one on first run. Leave it alone unless you
# need to rotate, or paste a value here to match an existing mod deployment.
# Localhost mod POSTs bypass this check — only remote mods need the key.
# PLAYERTRACKER_API_KEY=

# Optional: SMTP — enables email password reset from the login page.
# You can ALSO configure SMTP from the panel UI:
#   Permissions tab → Email / SMTP → Save → Send Test Email
# The panel UI takes precedence over these env vars when both are set.
# Works with any SMTP provider (Gmail App Password, SendGrid, Mailgun,
# Resend, Postmark, Fastmail, self-hosted Postfix, etc).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=you@gmail.com
